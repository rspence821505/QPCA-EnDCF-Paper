{
  "description": "Vega-Lite chart specifications for presentation figures",
  "note": "Most figures use pre-generated publication PNGs from paper/final_figures/. These specs are for potential interactive versions.",
  "charts": [
    {
      "name": "calibration_comparison_bar",
      "description": "Bar chart comparing spread-skill ratio across methods",
      "spec": {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
        "width": 400,
        "height": 300,
        "title": "Spread-Skill Ratio Comparison",
        "data": {
          "values": [
            {"method": "Seq-EnKF", "metric": "Spread-Skill γ̄", "value": 0.095},
            {"method": "4D-EnKF", "metric": "Spread-Skill γ̄", "value": 0.120},
            {"method": "QPCA-EnDCF", "metric": "Spread-Skill γ̄", "value": 0.811}
          ]
        },
        "mark": "bar",
        "encoding": {
          "x": {"field": "method", "type": "nominal", "sort": ["Seq-EnKF", "4D-EnKF", "QPCA-EnDCF"]},
          "y": {"field": "value", "type": "quantitative", "scale": {"domain": [0, 1]}},
          "color": {
            "field": "method",
            "scale": {"range": ["#ff6b6b", "#f9ca24", "#4ecdc4"]}
          }
        }
      }
    },
    {
      "name": "bias_variance_bar",
      "description": "Stacked bar chart of MSE decomposition",
      "spec": {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
        "width": 400,
        "height": 300,
        "title": "MSE Decomposition",
        "data": {
          "values": [
            {"method": "Seq-EnKF", "component": "Bias²", "value": 10.4},
            {"method": "Seq-EnKF", "component": "Variance", "value": 11.6},
            {"method": "4D-EnKF", "component": "Bias²", "value": 9.8},
            {"method": "4D-EnKF", "component": "Variance", "value": 11.2},
            {"method": "QPCA-EnDCF", "component": "Bias²", "value": 10.67},
            {"method": "QPCA-EnDCF", "component": "Variance", "value": 2.29}
          ]
        },
        "mark": "bar",
        "encoding": {
          "x": {"field": "method", "type": "nominal"},
          "y": {"field": "value", "type": "quantitative", "stack": true},
          "color": {"field": "component", "type": "nominal"}
        }
      }
    },
    {
      "name": "ensemble_size_scaling",
      "description": "RMSE vs ensemble size for all methods",
      "spec": {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
        "width": 500,
        "height": 300,
        "title": "RMSE vs Ensemble Size",
        "data": {
          "values": [
            {"method": "Seq-EnKF", "N": 5, "rmse": 4.71},
            {"method": "Seq-EnKF", "N": 10, "rmse": 4.51},
            {"method": "Seq-EnKF", "N": 20, "rmse": 3.95},
            {"method": "Seq-EnKF", "N": 50, "rmse": 3.55},
            {"method": "Seq-EnKF", "N": 100, "rmse": 3.39},
            {"method": "4D-EnKF", "N": 5, "rmse": 4.86},
            {"method": "4D-EnKF", "N": 10, "rmse": 4.42},
            {"method": "4D-EnKF", "N": 20, "rmse": 3.79},
            {"method": "4D-EnKF", "N": 50, "rmse": 3.49},
            {"method": "4D-EnKF", "N": 100, "rmse": 3.35},
            {"method": "QPCA-EnDCF", "N": 5, "rmse": 4.27},
            {"method": "QPCA-EnDCF", "N": 10, "rmse": 3.55},
            {"method": "QPCA-EnDCF", "N": 20, "rmse": 3.46},
            {"method": "QPCA-EnDCF", "N": 50, "rmse": 3.37},
            {"method": "QPCA-EnDCF", "N": 100, "rmse": 3.33}
          ]
        },
        "mark": {"type": "line", "point": true},
        "encoding": {
          "x": {"field": "N", "type": "quantitative", "scale": {"type": "log"}},
          "y": {"field": "rmse", "type": "quantitative"},
          "color": {"field": "method", "type": "nominal"}
        }
      }
    }
  ]
}
